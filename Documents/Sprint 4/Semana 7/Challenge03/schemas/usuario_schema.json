{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Usuario Response Schema",
  "description": "Schema de validação para resposta de busca de usuário por ID",
  "type": "object",
  "properties": {
    "nome": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "password": {
      "type": "string"
    },
    "administrador": {
      "type": "string",
      "enum": ["true", "false"]
    },
    "_id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9]{16}$",
      "description": "ID único do usuário com 16 caracteres alfanuméricos"
    }
  },
  "required": ["nome", "email", "password", "administrador", "_id"],
  "additionalProperties": false
}
