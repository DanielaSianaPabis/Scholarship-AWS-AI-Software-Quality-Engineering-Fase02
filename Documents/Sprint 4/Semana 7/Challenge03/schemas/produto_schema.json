{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Produto GET Response Schema",
  "description": "Schema de validação para resposta de busca de produto por ID",
  "type": "object",
  "properties": {
    "nome": {
      "type": "string"
    },
    "preco": {
      "type": "integer",
      "minimum": 0
    },
    "descricao": {
      "type": "string"
    },
    "quantidade": {
      "type": "integer",
      "minimum": 0
    },
    "_id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9]{16}$",
      "description": "ID único do produto com 16 caracteres alfanuméricos"
    }
  },
  "required": ["nome", "preco", "descricao", "quantidade", "_id"],
  "additionalProperties": false
}
